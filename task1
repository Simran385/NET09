class Parohod : Ustroystvo
{
    public Parohod(string name, string opisanie) : base(name, opisanie) { }

    public override void Sound()
    {
        Console.WriteLine("Ту-ту");
    }
}

class Program
{
    static void Main()
    {
        Chainik c = new Chainik("Чайник", "Кипятит воду");
        Mikrovolnovka m = new Mikrovolnovka("Микроволновка", "Разогревает еду");
        Avtomobil a = new Avtomobil("Автомобиль", "Перевозит людей");
        Parohod p = new Parohod("Пароход", "Плавает по воде");

        c.Show();
        c.Desc();
        c.Sound();

        Console.WriteLine();

        m.Show();
        m.Desc();
        m.Sound();

        Console.WriteLine();

        a.Show();
        a.Desc();
        a.Sound();

        Console.WriteLine();

        p.Show();
        p.Desc();
        p.Sound();
    }
}