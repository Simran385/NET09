using System;

class Ustroystvo
{
    public string name;
    public string opisanie;

    public Ustroystvo(string name, string opisanie)
    {
        this.name = name;
        this.opisanie = opisanie;
    }

    public virtual void Sound()
    {
        Console.WriteLine("Звук устройства");
    }

    public virtual void Show()
    {
        Console.WriteLine("Название: " + name);
    }

    public virtual void Desc()
    {
        Console.WriteLine("Описание: " + opisanie);
    }
}

class Chainik : Ustroystvo
{
    public Chainik(string name, string opisanie) : base(name, opisanie) { }

    public override void Sound()
    {
        Console.WriteLine("Свистит");
    }
}

class Mikrovolnovka : Ustroystvo
{
    public Mikrovolnovka(string name, string opisanie) : base(name, opisanie) { }

    public override void Sound()
    {
        Console.WriteLine("Жужжит");
    }
}

class Avtomobil : Ustroystvo
{
    public Avtomobil(string name, string opisanie) : base(name, opisanie) { }

    public override void Sound()
    {
        Console.WriteLine("Бип-бип");
